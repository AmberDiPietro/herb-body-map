<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Herbal Body Map — Body Into Balance</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Crimson+Pro:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0f0e0c; --surface:#1a1814; --surface2:#222019; --border:#3a3628;
  --gold:#c9a96e; --gold-light:#e8cc9a; --gold-dim:#7a6540;
  --text:#e8e0d0; --text-dim:#8a8070;
  --safe:#4a7c59; --safe-light:#6aab7a;
  --caution:#c4892a; --caution-light:#e8a83e;
  --avoid:#8b3a3a; --avoid-light:#c05050;
  --practitioner:#6b4a8b; --practitioner-light:#9b6abf;
  --some:#b07020; --some-light:#d4962a;
  --sys-digestive:#c9a96e; --sys-immune:#6aab7a; --sys-nervous:#7a9bc9;
  --sys-cardiovascular:#c97a7a; --sys-respiratory:#9ab8d4;
  --sys-musculoskeletal:#c4a96e; --sys-skin:#d4b896;
  --sys-reproductive:#c97aab; --sys-urinary:#7ac9c9;
  --sys-endocrine:#ab7ac9; --sys-mental:#7ab8ab;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:'Crimson Pro',Georgia,serif;min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.05'/%3E%3C/svg%3E");pointer-events:none;z-index:999;opacity:0.35;}

header{text-align:center;padding:2rem 2rem 1rem;border-bottom:1px solid var(--border);}
header h1{font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:300;color:var(--gold-light);letter-spacing:0.08em;margin-bottom:0.2rem;}
header p{font-size:0.95rem;color:var(--text-dim);font-style:italic;}

.layout{display:grid;grid-template-columns:200px 360px 1fr;min-height:calc(100vh - 110px);max-width:1400px;margin:0 auto;}

/* LEGEND */
.legend{padding:1.5rem 1rem;border-right:1px solid var(--border);display:flex;flex-direction:column;gap:1.2rem;}
.legend-title{font-size:0.65rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold-dim);margin-bottom:0.3rem;font-family:'Cormorant Garamond',serif;}
.sys-item{display:flex;align-items:center;gap:0.5rem;font-size:0.82rem;color:var(--text-dim);cursor:pointer;padding:0.28rem 0.4rem;border-radius:3px;transition:all 0.2s;border:1px solid transparent;}
.sys-item:hover{color:var(--text);background:var(--surface2);}
.sys-item.active{color:var(--gold-light);border-color:var(--border);background:var(--surface2);}
.sys-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0;}
.divider{height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);margin:0.3rem 0;}
.risk-item{display:flex;align-items:center;gap:0.5rem;font-size:0.78rem;color:var(--text-dim);}
.risk-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;}

/* BODY MAP */
.map-col{padding:1.2rem 0.5rem;display:flex;flex-direction:column;align-items:center;border-right:1px solid var(--border);}
.map-col svg{width:100%;max-width:320px;height:auto;}
.body-region{cursor:pointer;transition:all 0.2s;}
.body-region path,.body-region ellipse,.body-region circle{transition:all 0.25s;}
.body-region:hover path,.body-region:hover ellipse,.body-region:hover circle{filter:brightness(1.4) drop-shadow(0 0 6px currentColor);}
.body-region.active path,.body-region.active ellipse,.body-region.active circle{filter:brightness(1.6) drop-shadow(0 0 10px currentColor);}
.region-label{font-family:'Crimson Pro',serif;font-size:9.5px;fill:var(--text-dim);pointer-events:none;transition:fill 0.2s;letter-spacing:0.04em;}
.body-region:hover .region-label,.body-region.active .region-label{fill:var(--gold-light);}

/* DETAIL PANEL */
.detail-col{display:grid;grid-template-columns:1fr 1fr;overflow:hidden;}

.herb-list-panel{border-right:1px solid var(--border);padding:1.2rem;overflow-y:auto;max-height:calc(100vh - 110px);}
.herb-profile-panel{padding:1.2rem;overflow-y:auto;max-height:calc(100vh - 110px);}

.panel-title{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:300;color:var(--gold-light);margin-bottom:0.2rem;}
.panel-subtitle{font-size:0.8rem;color:var(--text-dim);font-style:italic;margin-bottom:1rem;}

/* Filters */
.filters{display:flex;gap:0.3rem;flex-wrap:wrap;margin-bottom:0.8rem;}
.fbtn{padding:0.2rem 0.6rem;border-radius:20px;font-size:0.72rem;font-family:'Crimson Pro',serif;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--text-dim);transition:all 0.2s;}
.fbtn:hover{border-color:var(--gold-dim);color:var(--text);}
.fbtn.active{background:var(--surface2);border-color:var(--gold);color:var(--gold-light);}

.search{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:4px;padding:0.4rem 0.7rem;color:var(--text);font-family:'Crimson Pro',serif;font-size:0.88rem;margin-bottom:0.8rem;outline:none;transition:border-color 0.2s;}
.search:focus{border-color:var(--gold-dim);}
.search::placeholder{color:var(--text-dim);font-style:italic;}

/* Herb cards */
.herb-card{background:var(--surface);border:1px solid var(--border);border-radius:4px;padding:0.6rem 0.8rem;margin-bottom:0.35rem;cursor:pointer;transition:all 0.2s;position:relative;overflow:hidden;}
.herb-card::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;}
.herb-card.safe::before{background:var(--safe-light);}
.herb-card.caution::before{background:var(--caution-light);}
.herb-card.avoid::before{background:var(--avoid-light);}
.herb-card.practitioner::before{background:var(--practitioner-light);}
.herb-card.some-cautions::before{background:var(--some-light);}
.herb-card:hover{border-color:var(--gold-dim);background:var(--surface2);transform:translateX(2px);}
.herb-card.selected{border-color:var(--gold);background:var(--surface2);}
.herb-card .hname{font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--text);margin-bottom:0.15rem;}
.herb-card .hrisk{font-size:0.72rem;font-style:italic;margin-bottom:0.25rem;}
.herb-card.safe .hrisk{color:var(--safe-light);}
.herb-card.caution .hrisk{color:var(--caution-light);}
.herb-card.avoid .hrisk{color:var(--avoid-light);}
.herb-card.practitioner .hrisk{color:var(--practitioner-light);}
.herb-card.some-cautions .hrisk{color:var(--some-light);}
.herb-card .htags{display:flex;flex-wrap:wrap;gap:0.2rem;}
.tag{font-size:0.65rem;padding:0.08rem 0.4rem;border-radius:10px;background:var(--bg);border:1px solid var(--border);color:var(--text-dim);}

/* Profile panel */
.empty-profile{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;text-align:center;color:var(--text-dim);gap:0.8rem;}
.empty-icon{font-size:2.5rem;opacity:0.25;}
.empty-profile p{font-style:italic;font-size:0.9rem;max-width:180px;line-height:1.6;}

.profile-wrap{display:none;}
.profile-wrap.visible{display:block;}
.empty-profile.hidden{display:none;}

.profile-herb-name{font-family:'Cormorant Garamond',serif;font-size:1.7rem;font-weight:300;color:var(--gold-light);line-height:1.2;margin-bottom:0.1rem;}
.profile-latin{font-size:0.82rem;color:var(--text-dim);font-style:italic;margin-bottom:0.8rem;}
.profile-risk{display:inline-block;font-size:0.75rem;padding:0.2rem 0.7rem;border-radius:12px;margin-bottom:1rem;font-style:italic;}
.profile-risk.safe{background:#1a3025;color:var(--safe-light);border:1px solid var(--safe);}
.profile-risk.caution{background:#2a1e0a;color:var(--caution-light);border:1px solid var(--caution);}
.profile-risk.avoid{background:#2a1010;color:var(--avoid-light);border:1px solid var(--avoid);}
.profile-risk.practitioner{background:#1a1028;color:var(--practitioner-light);border:1px solid var(--practitioner);}
.profile-risk.some-cautions{background:#2a1a05;color:var(--some-light);border:1px solid var(--some);}

.section-label{font-size:0.62rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--gold-dim);margin-bottom:0.4rem;margin-top:0.9rem;font-family:'Cormorant Garamond',serif;}
.tag-row{display:flex;flex-wrap:wrap;gap:0.25rem;margin-bottom:0.3rem;}
.atag{font-size:0.7rem;padding:0.15rem 0.5rem;border-radius:10px;background:var(--surface2);border:1px solid var(--border);color:var(--text);}
.atag.action{border-color:#3a4a6a;color:#9ab8d4;}
.atag.ailment{border-color:#3a5a3a;color:#6aab7a;}
.atag.method{border-color:#5a4a2a;color:var(--gold);}
.atag.taste{border-color:#4a3a5a;color:#c97aab;}
.atag.avail{border-color:#2a4a4a;color:#7ac9c9;}
.atag.preferred{border-color:var(--gold-dim);color:var(--gold-light);background:#2a2010;}

.cautions-box{background:var(--surface2);border:1px solid #3a2020;border-left:3px solid var(--avoid);border-radius:4px;padding:0.6rem 0.8rem;margin-top:0.5rem;}
.cautions-box p{font-size:0.78rem;color:#c8a8a0;line-height:1.6;font-style:italic;}

.no-cautions{font-size:0.78rem;color:var(--safe-light);font-style:italic;margin-top:0.3rem;}

::-webkit-scrollbar{width:3px;}
::-webkit-scrollbar-track{background:transparent;}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px;}

.map-hint{font-size:0.72rem;color:var(--text-dim);font-style:italic;text-align:center;margin-top:0.5rem;opacity:0.7;}
</style>
</head>
