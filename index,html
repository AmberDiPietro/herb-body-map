  "Immune System":"var(--sys-immune)",
  "Respiratory System":"var(--sys-respiratory)",
  "Musculoskeletal System":"var(--sys-musculoskeletal)",
  "Skin/Integumentary":"var(--sys-skin)",
  "Urinary System":"var(--sys-urinary)",
  "Reproductive System":"var(--sys-reproductive)",
  "Endocrine System":"var(--sys-endocrine)"
};

let currentSystem = null;
let currentRisk = 'all';
let selectedHerb = null;

function getRiskClass(risk) {
  if (!risk) return 'safe';
  const r = risk.toLowerCase();
  if (r.includes('generally safe')) return 'safe';
  if (r.includes('avoid')) return 'avoid';
  if (r.includes('caution in pregnancy')) return 'caution';
  if (r.includes('some cautions')) return 'some-cautions';
  if (r.includes('practitioner')) return 'practitioner';
  return 'safe';
}

function selectSystem(name, el) {
  document.querySelectorAll('.body-region').forEach(r => r.classList.remove('active'));
  if (el) el.classList.add('active');
  document.querySelectorAll('.sys-item').forEach(i => i.classList.toggle('active', i.dataset.system === name));
  currentSystem = name;
  currentRisk = 'all';
  selectedHerb = null;
  document.querySelectorAll('.fbtn').forEach((b,i) => b.classList.toggle('active', i===0));
  document.getElementById('searchInput').value = '';
  document.getElementById('listEmpty').style.display = 'none';
  document.getElementById('listContent').style.display = 'block';
  document.getElementById('listTitle').textContent = name;
  document.getElementById('profileEmpty').classList.remove('hidden');
  document.getElementById('profileContent').classList.remove('visible');
  document.getElementById('profileEmpty').style.display = 'flex';
  document.getElementById('profileContent').style.display = 'none';
  renderList();
}

function renderList() {
  if (!currentSystem) return;
  const herbs = DATA[currentSystem] || [];
  const search = document.getElementById('searchInput').value.toLowerCase();
  const filtered = herbs.filter(h => {
    const rc = getRiskClass(h.risk);
    const rm = currentRisk === 'all' || rc === currentRisk || (currentRisk === 'caution' && rc === 'some-cautions');
    const sm = !search || h.name.toLowerCase().includes(search) || h.actions.some(a => a.toLowerCase().includes(search));
    return rm && sm;
  });
  document.getElementById('listSubtitle').textContent = filtered.length + ' of ' + herbs.length + ' herbs';
  document.getElementById('herbCards').innerHTML = filtered.map(h => {
    const rc = getRiskClass(h.risk);
    const isSelected = selectedHerb && selectedHerb.name === h.name;
    return '<div class="herb-card ' + rc + (isSelected ? ' selected' : '') + '" onclick=\'selectHerb(' + JSON.stringify(JSON.stringify(h)) + ')\'>' +
      '<div class="hname">' + h.name + '</div>' +
      '<div class="hrisk ' + rc + '">' + h.risk + '</div>' +
      '<div class="htags">' + h.actions.slice(0,3).map(a => '<span class="tag">' + a + '</span>').join('') + '</div>' +
      '</div>';
  }).join('');
}

function selectHerb(jsonStr) {
  const h = JSON.parse(jsonStr);
  selectedHerb = h;
  renderList();

  const rc = getRiskClass(h.risk);
  const methodsHtml = h.all_methods && h.all_methods.length ?
    h.all_methods.map(m => '<span class="atag method' + (m === h.preferred_method ? ' preferred' : '') + '">' + m + (m === h.preferred_method ? ' ★' : '') + '</span>').join('') : '<span style="color:var(--text-dim);font-size:0.78rem;font-style:italic;">Not specified</span>';

  const ailmentsHtml = h.ailments && h.ailments.length ?
    h.ailments.map(a => '<span class="atag ailment">' + a + '</span>').join('') : '<span style="color:var(--text-dim);font-size:0.78rem;font-style:italic;">Not listed</span>';

  const tasteHtml = h.taste && h.taste !== 'Not specified' ?
    h.taste.split(',').slice(0,4).map(t => '<span class="atag taste">' + t.trim() + '</span>').join('') : '<span style="color:var(--text-dim);font-size:0.78rem;font-style:italic;">Not recorded</span>';

  const availHtml = h.availability && h.availability.length ?
    h.availability.map(a => '<span class="atag avail">' + a + '</span>').join('') : '<span style="color:var(--text-dim);font-size:0.78rem;font-style:italic;">Not specified</span>';

  const cautionsHtml = h.cautions ?
    '<div class="cautions-box"><p>' + h.cautions + (h.cautions.length >= 198 ? '...' : '') + '</p></div>' :
    '<p class="no-cautions">No specific cautions noted — generally considered safe.</p>';

  const pc = document.getElementById('profileContent');
  pc.innerHTML =
    '<div class="profile-herb-name">' + h.name + '</div>' +
    (h.latin ? '<div class="profile-latin">' + h.latin + '</div>' : '') +
    '<div class="profile-risk ' + rc + '">' + h.risk + '</div>' +
    '<div class="section-label">Herbal Actions</div>' +
    '<div class="tag-row">' + h.actions.map(a => '<span class="atag action">' + a + '</span>').join('') + '</div>' +
    '<div class="section-label">Conditions & Ailments</div>' +
    '<div class="tag-row">' + ailmentsHtml + '</div>' +
    '<div class="section-label">Preparation Methods</div>' +
    '<div class="tag-row">' + methodsHtml + '</div>' +
    '<div class="section-label">Taste Profile</div>' +
    '<div class="tag-row">' + tasteHtml + '</div>' +
    '<div class="section-label">Availability</div>' +
    '<div class="tag-row">' + availHtml + '</div>' +
    '<div class="section-label">Cautions & Safety</div>' +
    cautionsHtml;

  pc.style.display = 'block';
  document.getElementById('profileEmpty').style.display = 'none';
}

function filterRisk(r, btn) {
  currentRisk = r;
  document.querySelectorAll('.fbtn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderList();
}

// Build legend
const legend = document.getElementById('sysLegend');
Object.keys(DATA).forEach(sys => {
  const d = document.createElement('div');
  d.className = 'sys-item';
  d.dataset.system = sys;
  d.innerHTML = '<div class="sys-dot" style="background:' + SYS_COLORS[sys] + '"></div>' + sys;
  d.onclick = () => {
    const el = document.querySelector('[data-system="' + sys + '"]');
    selectSystem(sys, el);
  };
  legend.appendChild(d);
});
</script>
</body>
</html>
